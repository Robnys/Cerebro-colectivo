// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Core Tables
model Company {
  id                String    @id @default(cuid())
  name              String
  domain            String?   @unique
  plan              Plan      @default(FREE)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  // Relations
  users             User[]
  integrations      Integration[]
  slackMessages     SlackMessage[]
  notionPages       NotionPage[]
  searchQueries     SearchQuery[]
  sharedInsights    SharedInsight[]
  
  @@map("companies")
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  companyId         String
  role              UserRole  @default(MEMBER)
  lastActive        DateTime? @default(now())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  // Relations
  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  searchQueries     SearchQuery[]
  userSessions      UserSession[]
  sharedInsights    SharedInsight[]
  
  @@map("users")
}

model Integration {
  id                String              @id @default(cuid())
  companyId         String
  type              IntegrationType
  credentials       Json                // Encrypted OAuth tokens
  status            IntegrationStatus   @default(PENDING)
  lastSync          DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  // Relations
  company           Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  @@map("integrations")
}

// Knowledge Storage
model SlackMessage {
  id                String    @id @default(cuid())
  companyId         String
  messageId         String    @unique
  channelId         String
  userId            String
  text              String
  timestamp         DateTime
  threadId          String?
  replyCount        Int       @default(0)
  reactionCount     Int       @default(0)
  createdAt         DateTime  @default(now())
  
  // Relations
  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vectorEmbeddings  VectorEmbedding[]
  knowledgeHits     KnowledgeHit[]
  
  @@map("slack_messages")
}

model NotionPage {
  id                String    @id @default(cuid())
  companyId         String
  pageId            String    @unique
  databaseId        String?
  title             String
  content           String    // Raw content
  lastModified      DateTime
  createdBy         String?
  url               String?
  createdAt         DateTime  @default(now())
  
  // Relations
  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vectorEmbeddings  VectorEmbedding[]
  knowledgeHits     KnowledgeHit[]
  
  @@map("notion_pages")
}

model VectorEmbedding {
  id                String    @id @default(cuid())
  sourceType        SourceType
  sourceId          String
  embedding         Float[]   // Vector representation
  metadata          Json?     // Additional context
  createdAt         DateTime  @default(now())
  
  // Relations
  slackMessage      SlackMessage? @relation(fields: [sourceId], references: [messageId], onDelete: Cascade)
  notionPage        NotionPage?   @relation(fields: [sourceId], references: [pageId], onDelete: Cascade)
  
  @@unique([sourceType, sourceId])
  @@map("vector_embeddings")
}

// Search & Analytics
model SearchQuery {
  id                String    @id @default(cuid())
  userId            String
  query             String
  resultsCount      Int
  responseTime      Int       // in milliseconds
  confidenceScore    Float?
  createdAt         DateTime  @default(now())
  
  // Relations
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  company           Company   @relation(fields: [user], references: [userId])
  knowledgeHits     KnowledgeHit[]
  
  @@map("search_queries")
}

model UserSession {
  id                String    @id @default(cuid())
  userId            String
  startTime         DateTime  @default(now())
  endTime           DateTime?
  queriesCount      Int       @default(0)
  ipAddress         String?
  userAgent         String?
  
  // Relations
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("user_sessions")
}

model KnowledgeHit {
  id                String    @id @default(cuid())
  queryId           String
  sourceType        SourceType
  sourceId          String
  relevanceScore    Float
  position          Int       // Position in search results
  createdAt         DateTime  @default(now())
  
  // Relations
  searchQuery       SearchQuery @relation(fields: [queryId], references: [id], onDelete: Cascade)
  slackMessage      SlackMessage? @relation(fields: [sourceId], references: [messageId], onDelete: Cascade)
  notionPage        NotionPage?   @relation(fields: [sourceId], references: [pageId], onDelete: Cascade)
  
  @@map("knowledge_hits")
}

// Viral Loop
model SharedInsight {
  id                String    @id @default(cuid())
  userId            String
  query             String
  answer            String
  shareToken        String    @unique @default(cuid())
  views             Int       @default(0)
  conversions       Int       @default(0)
  isActive          Boolean   @default(true)
  expiresAt         DateTime  @default(dbgenerated("(now() + interval '30 days')"))
  createdAt         DateTime  @default(now())
  
  // Relations
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  company           Company   @relation(fields: [user], references: [userId])
  
  @@map("shared_insights")
}

// Enums
enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum UserRole {
  ADMIN
  MEMBER
  VIEWER
}

enum IntegrationType {
  SLACK
  NOTION
  GOOGLE_DRIVE
  JIRA
}

enum IntegrationStatus {
  PENDING
  ACTIVE
  ERROR
  DISABLED
}

enum SourceType {
  SLACK_MESSAGE
  NOTION_PAGE
  GOOGLE_DOC
  JIRA_ISSUE
}
